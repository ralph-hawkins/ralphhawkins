<!DOCTYPE html>
<html lang="en">
<head>
    {% include "head-common.njk" %}
    <script src="/js/header-parallax.js" defer></script>
    <script src="/js/post-nav-arrow.js" defer></script>
    <script src="/js/auto-scroll.js"></script>
    {% if tags and 'weeknotes' in tags %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "{{ title }}",
      "datePublished": "{{ date | isoDate }}",
      "author": {
        "@type": "Person",
        "name": "Ralph Hawkins",
        "url": "{{ site.url }}"
      },
      "publisher": {
        "@type": "Person",
        "name": "Ralph Hawkins"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}"
      }
    }
    </script>
    {% else %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ralph Hawkins",
      "url": "{{ site.url }}",
      "author": {
        "@type": "Person",
        "name": "Ralph Hawkins",
        "jobTitle": "Service Designer",
        "worksFor": {
          "@type": "Organization",
          "name": "NHS England"
        }
      }
    }
    </script>
    {% endif %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  <header>
    <div class="container">
      <h1>
        EXTERNAL Hawkins
      </h1>
      <p>
        I’m a service designer who works in the public sector,
        currently with NHS England helping people stay healthy.
      </p>
      {% if page.url.startsWith('/graphic-design/') %}
      <p>I also studied graphic design.</p>
      {% endif %}
    </div>
  </header>
  <main id="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>
    {% include "footer.njk" %}
</body>
</html>
