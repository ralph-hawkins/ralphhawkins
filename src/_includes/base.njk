{#- Set `hero: false` in front matter to drop the hero header and its scripts
   (pages like the notes list supply their own h1). The scripts are tied to
   the hero on purpose: header-bars.js needs the <header>, and auto-scroll.js
   would scroll to the first .date element it finds — on a listing page
   that's a list item's date, not a post date. -#}
<!DOCTYPE html>
<html lang="en">
<head>
    {% include "head-common.njk" %}
    {%- if hero !== false %}
    <script src="/js/header-bars.js" defer></script>
    <script src="/js/post-nav-arrow.js" defer></script>
    <script src="/js/auto-scroll.js" defer></script>
    {%- endif %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  {%- if hero !== false %}
  <header>
    <div class="container">
      <h1>
        External Hawkins
      </h1>
      <p>
        I’m a service designer who works in the public sector,
        currently with NHS England helping people stay healthy.
      </p>
      {% if page.url.startsWith('/graphic-design/') %}
      <p>I also studied graphic design.</p>
      {% else %}
      <p>
        These are my week notes.
      </p>
      {% endif %}
    </div>
  </header>
  {%- endif %}
  <main id="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>
    {% include "footer.njk" %}
</body>
</html>
