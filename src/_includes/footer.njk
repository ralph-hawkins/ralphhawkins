<footer>
  <hr>
  <div class="container">
  {% if page.url == '/graphic-design/' %}
    {# Gallery page - show link to latest public week note (excludes preview posts) #}
    <h2>Week notes</h2>
    {% set latestPost = collections.publicWeeknotes | reverse | first %}
    {% if latestPost %}
      <p><a href="{{ latestPost.url }}">Latest week note – {{ latestPost.data.title }}</a></p>
      <a href="/notes-list/">All week notes</a>
    {% endif %}
  {% else %}
    {# Week note pages - show prev/next navigation #}
    {% set previousPost = collections.publicWeeknotes | getPrevPost(page) %}
    {% set nextPost = collections.publicWeeknotes | getNextPost(page) %}

    {% if previousPost or nextPost %}
      <h2>More week notes</h2>
      <nav aria-label="Post navigation" class="post-nav">
        {% if nextPost %}
          <p class="post-nav-link post-nav-next">
            <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
          </p>
        {% endif %}
        {% if previousPost %}
          <p class="post-nav-link post-nav-prev">
            <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
          </p>
        {% endif %}
        <a href="/notes-list/">All week notes</a>
      </nav>
    {% endif %}
  {% endif %}

  {% if page.url != '/graphic-design/' %}
    <h2>Other</h2>
    <a href="/graphic-design/">Graphic design</a>
  {% endif %}

    <h2>Contact</h2>
    <ul>
      <li><a href="mailto:info@ralphhawkins.co.uk">info@ralphhawkins.co.uk</a></li>
      <li><a href="https://bsky.app/profile/ralphhawkins.bsky.social">Bluesky</a></li>
      <li><a href="https://www.linkedin.com/in/ralph-hawkins-624ba893/">LinkedIn</a></li>
    </ul>
  </div>
</footer>
