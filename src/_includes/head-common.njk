{# Shared <head> contents for all layouts. #}
{%- set metaDescription = description if description else "Ralph Hawkins is a service designer working in the public sector with NHS England, helping people stay healthy." -%}
{%- if not description and content -%}{%- set metaDescription = content | striptags | truncate(155) -%}{%- endif -%}
{%- set pageTitle = title if title else "Ralph Hawkins" -%}
{%- set ogType = "article" if (tags and 'weeknotes' in tags) else "website" -%}
{#- Explicit image front matter wins; otherwise week notes and the homepage
    get a generated card (see src/_11ty/og-images.js). -#}
{%- set ogImage = image -%}
{%- if not ogImage and tags and 'weeknotes' in tags -%}{%- set ogImage = '/images/og/' + page.fileSlug + '.png' -%}{%- endif -%}
{%- if not ogImage and page.url == '/' -%}{%- set ogImage = '/images/og/home.png' -%}{%- endif -%}
<meta charset="UTF-8">
<!-- Preload fonts -->
<link rel="preload" href="/fonts/volksans/volksans-Normal.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/volksans/volksans-SemiBold.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/volksans/volksans-Bold.woff2" as="font" type="font/woff2" crossorigin>
<link rel="icon" type="image/png" href="/images/favicon.png">
{%- if tags and 'weeknotes' in tags %}
{#- Post pages get an SVG favicon in the post's seeded blob colours; the PNG
    above stays as the fallback for browsers without SVG favicon support. #}
<link rel="icon" type="image/svg+xml" href="{{ page.fileSlug | blobFavicon }}">
{%- endif %}
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{%- if tags and 'weeknotes' in tags %}
{#- Browser chrome tints to the post's blob colour. #}
<meta name="theme-color" content="hsl({{ page.fileSlug | blobHue }}, 90%, 72%)">
{%- else %}
<meta name="theme-color" content="#EBEDF0">
{%- endif %}
<meta name="description" content="{{ metaDescription }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- Open Graph / Twitter -->
<meta property="og:type" content="{{ ogType }}">
<meta property="og:site_name" content="Ralph Hawkins">
<meta property="og:locale" content="en_GB">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ metaDescription }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
{%- if ogImage %}
<meta property="og:image" content="{{ site.url }}{{ ogImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ pageTitle }}">
<meta name="twitter:card" content="summary_large_image">
{%- else %}
<meta name="twitter:card" content="summary">
{%- endif %}
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ metaDescription }}">
{%- if ogImage %}
<meta name="twitter:image" content="{{ site.url }}{{ ogImage }}">
{%- endif %}

<link rel="stylesheet" href="/css/main.css">
<title>{% if title %}{{ title }} – {% endif %}Ralph Hawkins</title>

{# Structured data, defined once for every layout. Week notes describe a
   BlogPosting; every other page describes the site as a whole. #}
{% if tags and 'weeknotes' in tags %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  {#- dump JSON-encodes the value (quotes included) and safe skips HTML
     autoescaping — inside a script block entities like &quot; would be
     read as literal text, not decoded. #}
  "headline": {{ title | dump | safe }},
  "datePublished": "{{ date | isoDate }}",
  "author": {
    "@type": "Person",
    "name": "Ralph Hawkins",
    "url": "{{ site.url }}"
  },
  "publisher": {
    "@type": "Person",
    "name": "Ralph Hawkins"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>
{% else %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Ralph Hawkins",
  "url": "{{ site.url }}",
  "author": {
    "@type": "Person",
    "name": "Ralph Hawkins",
    "jobTitle": "Service Designer",
    "worksFor": {
      "@type": "Organization",
      "name": "NHS England"
    }
  }
}
</script>
{% endif %}

<script src="/js/random-gradients.js"></script>
